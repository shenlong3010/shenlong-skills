{
  "$comment": "Sample .mcp.json — credentials via env expansion only; never literals.",
  "mcpServers": {
    "cache-proxy": {
      "command": "python3",
      "args": ["mcp/cache-proxy/server.py"],
      "$comment": "caching proxy — see mcp/cache-proxy/README.md; move direct entries into its upstreams.json"
    },
    "example-service": {
      "command": "python3",
      "args": ["servers/example_service.py"],
      "env": { "SERVICE_API_KEY": "${SERVICE_API_KEY}" }
    }
  }
}
