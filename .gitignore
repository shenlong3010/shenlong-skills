# Runtime state from ralph loop runs (per-engineer scratch, never tracked).
# Ralph inputs are fetch-local -> execute -> delete: backlog files are working
# state, ignored even at repo root so an accidental `git add` can't track them.
.agents/
/BACKLOG.md

# Session worktrees
.claude/worktrees/

# Internal design notes/screenshots — must never be committed (public repo)
workspace/

# Local secret/term scan list — contents are private
.wordlist

# Eval runner output
evals/results/

# Proprietary vendored docs (local fetch only)
vendor/anthropic/

# Local Claude Code config — personal, per-machine; ship .mcp.json.sample instead
.mcp.json
.claude/settings.local.json

# cache-proxy live upstreams — machine-local; ship upstreams.sample.json instead
mcp/cache-proxy/upstreams.json

# Python bytecode
__pycache__/
*.pyc
