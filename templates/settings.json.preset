{
  "$comment": "Starter project .claude/settings.json — trim to taste.",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/hooks/guard-dangerous.sh" } ] }
    ]
  }
}
