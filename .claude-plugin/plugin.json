{
  "name": "shenlong-skills",
  "version": "0.3.1",
  "description": "Personal toolbox: skills, commands, agents, hooks, MCP scaffolds, styles, templates.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-dangerous.sh\"", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/autoformat.sh\"", "timeout": 30 }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/notify.sh\"", "timeout": 5 },
          { "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/cost-logger.sh\"", "timeout": 5 }
        ]
      }
    ]
  }
}
